# MongoDB — MUST include database name before the ?
# Wrong:   mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
# Correct: mongodb+srv://user:pass@cluster.mongodb.net/a786?appName=Cluster0
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/a786?appName=Cluster0

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-64-char-hex-string-here

# Production: your Vercel domain. Local: http://localhost:3000
NEXTAUTH_URL=https://your-project.vercel.app
