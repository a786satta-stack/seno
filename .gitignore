# --- Dependencies ---
# Never track the heavy node_modules folder
node_modules/
.pnp
.pnp.js

# --- Environment / Secrets ---
# Keep your API keys and secrets local
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# --- Build Outputs ---
# Only track source code, not generated files
dist/
build/
out/
.next/
bin/
obj/

# --- Debug & Logs ---
# Error logs and system diagnostics
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.pnpm-debug.log*

# --- IDE & Editor Settings ---
# Remove personal editor configurations
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Testing ---
# Coverage reports from Jest or Vitest
coverage/
.nyc_output/

# --- Temporary Files ---
# Cache and temporary system files
.cache/
.eslintcache
.stylelintcache

# --- Development Scripts ---
# Seeding and local utility scripts
scripts/